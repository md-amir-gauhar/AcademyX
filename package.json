{
  "name": "AcademyX",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:web": "bun --cwd apps/web dev",
    "dev:api": "bun --cwd apps/api dev",
    "dev:admin": "bun --cwd apps/admin dev",
    "build": "bunx bun-workspaces run build --dep-order",
    "lint": "bunx bun-workspaces run lint",
    "test": "bunx bun-workspaces run test",
    "ls": "bunx bun-workspaces ls --json --pretty"
  },
  "devDependencies": {
    "bun-workspaces": "^1.5.2"
  },
  "overrides": {
    "@types/express-serve-static-core": "5.0.7"
  }
}
