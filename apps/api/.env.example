PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/database_name
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=your-email@example.com
FRONTEND_URL=http://localhost:3001
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Encryption Key (Required - for encrypting sensitive data like Razorpay keys)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_character_hex_encryption_key_generate_with_openssl_rand_hex_32

# Redis Configuration (Required - for caching and OTP)
REDIS_URL=redis://localhost:6379

# AuthKey SMS Configuration (for OTP)
AUTHKEY_API_KEY=your_authkey_api_key_here

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=your-bucket-name

# AWS CloudFront (Optional - for CDN)
AWS_CLOUDFRONT_DOMAIN=d111111abcdef8.cloudfront.net

# Razorpay Configuration (for payments)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
